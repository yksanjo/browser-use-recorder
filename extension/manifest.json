{
  "manifest_version": 3,
  "name": "Browser Use Recorder",
  "version": "1.0.0",
  "description": "Record browser interactions for automation code generation",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/record-16.png",
      "48": "icons/record-48.png",
      "128": "icons/record-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
